<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/product_list_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/product_list_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:contentDescription="화면 제목 상품목록"
        android:text="상품목록"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/product_filter_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:contentDescription="현재 상품 필터"
        android:text="현재 필터: 전체" />

    <HorizontalScrollView
        android:id="@+id/filter_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:contentDescription="상품 필터 목록">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/filter_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="상품 필터 전체"
                android:text="전체" />

            <Button
                android:id="@+id/filter_electronics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="상품 필터 전자제품"
                android:text="전자제품" />

            <Button
                android:id="@+id/filter_living"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="상품 필터 생활용품"
                android:text="생활용품" />

            <Button
                android:id="@+id/filter_popular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="상품 필터 인기상품"
                android:text="인기상품" />

            <Button
                android:id="@+id/filter_reset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="필터 초기화"
                android:text="필터 초기화" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/product_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:contentDescription="상품 카드 리스트" />
</LinearLayout>
